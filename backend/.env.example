# Base Configs
APP_ENV=development
DEBUG=True
SECRET_KEY=supersecret-token-key-for-jwt-signing-change-in-production

# Databases
DATABASE_URL=postgresql+psycopg2://postgres:postgrespassword@localhost:5432/auto_ide
REDIS_URL=redis://localhost:6379/0

# Docker Socket (leave blank if local daemon default, e.g., unix:///var/run/docker.sock)
DOCKER_HOST=unix:///var/run/docker.sock

# AI Model Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL_NAME=gpt-4o

# Integrations
GITHUB_TOKEN=your-github-personal-access-token-here
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=onboarding@resend.dev

# External URLs (for redirection and absolute links)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
